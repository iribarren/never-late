# Copy this file to .env and fill in real values for local dev:
#   cp .env.example .env
#
# .env is gitignored — never commit real secrets. docker-compose.yml loads this file into both
# the backend container's environment and the Postgres container's bootstrap environment.

# --- Postgres (consumed by the `db` service in docker-compose.yml) ---
POSTGRES_DB=neverlate
POSTGRES_USER=neverlate
POSTGRES_PASSWORD=change-me-in-real-envs

# --- Backend (consumed by Config.fromEnv() — see src/main/kotlin/com/neverlate/backend/Config.kt) ---
PORT=8080
# DATABASE_URL points at the `db` service by its docker-compose network name, not localhost.
DATABASE_URL=jdbc:postgresql://db:5432/neverlate
DATABASE_USER=neverlate
DATABASE_PASSWORD=change-me-in-real-envs

# HMAC-SHA256 signing secret for JWTs. Generate a real one for anything beyond a throwaway local
# instance, e.g.: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string
JWT_ISSUER=never-late-backend
JWT_AUDIENCE=never-late-app
JWT_EXPIRY_HOURS=24
