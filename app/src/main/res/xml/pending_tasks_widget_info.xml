<?xml version="1.0" encoding="utf-8"?>
<!--
    App Widget metadata for PendingTasksWidget (feature 05).

    updatePeriodMillis="0" deliberately disables the system's own periodic-update mechanism: this
    project drives refreshes explicitly instead, via WidgetRefreshingTaskRepository (on every
    task write) and WidgetRefreshWorker (a WorkManager PeriodicWorkRequest every ~15 min) — see
    those classes' KDoc. Relying on updatePeriodMillis here would mean two competing refresh
    schedules with no clear owner.
-->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="250dp"
    android:minHeight="110dp"
    android:targetCellWidth="4"
    android:targetCellHeight="2"
    android:updatePeriodMillis="0"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen"
    android:description="@string/widget_pending_tasks_description" />
