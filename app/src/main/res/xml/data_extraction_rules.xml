<?xml version="1.0" encoding="utf-8"?>
<!--
  Backup/transfer rules for Android 12 (API 31) and above (android:dataExtractionRules).

  Same reasoning as backup_rules.xml: the Keystore-sealed "auth_secure_prefs" file is excluded from
  BOTH cloud backup and device-to-device transfer, because its hardware-bound key can't follow the
  file to the destination, so a restored copy would only crash the app with AEADBadTagException.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="auth_secure_prefs.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="auth_secure_prefs.xml" />
    </device-transfer>
</data-extraction-rules>
