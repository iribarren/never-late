<?xml version="1.0" encoding="utf-8"?>
<!--
  English translations (values-en). Selected automatically when the device language is English;
  otherwise Android falls back to the base res/values/strings.xml (Spanish). Every `name` here
  must mirror a `name` in the base file — the Translation lint inspection flags any that drift.
-->
<resources>
    <string name="app_name">Never Late</string>

    <!-- Onboarding screen -->
    <string name="onboarding_title">Welcome</string>
    <string name="onboarding_prompt">What\'s your name?</string>
    <string name="onboarding_name_label">Your name</string>
    <string name="onboarding_save_button">Save</string>

    <!-- Home screen -->
    <string name="home_greeting">Hi, %1$s</string>
    <string name="home_option_tasks">Tasks</string>
    <!-- Feature 15: one-line description shown below the label in the rich ListItem row. -->
    <string name="home_option_tasks_description">Manage your tasks and their deadlines.</string>
    <string name="home_option_articles">Articles</string>
    <string name="home_option_articles_description">Tips and articles to help you manage your time.</string>
    <string name="home_settings_content_description">Settings</string>

    <!-- Settings screen (feature 07) -->
    <string name="settings_title">Settings</string>
    <string name="settings_back_content_description">Back</string>
    <string name="settings_theme_section">Theme</string>
    <string name="settings_theme_light">Light</string>
    <string name="settings_theme_dark">Dark</string>
    <string name="settings_theme_system">Follow the system</string>

    <!-- Settings screen: Material You / dynamic color (feature 16). Switch on = system (wallpaper) colors; off = app's own brand colors. Hidden below Android 12. -->
    <string name="settings_dynamic_color_label">Use system colors (Material You)</string>

    <!-- Settings screen: reminders (feature 09) -->
    <string name="settings_reminders_section">Reminders</string>
    <string name="settings_reminders_enabled_label">Remind me before a task is due</string>
    <string name="settings_reminder_lead_time_label">Remind me</string>
    <!-- Lead-time choice, e.g. "5 minutes before". %1$d is the number of minutes. -->
    <plurals name="settings_reminder_lead_minutes">
        <item quantity="one">%1$d minute before</item>
        <item quantity="other">%1$d minutes before</item>
    </plurals>
    <string name="settings_exact_alarm_notice">For reminders to sound at the exact time, grant the alarms &amp; reminders permission.</string>
    <string name="settings_exact_alarm_action">Open settings</string>

    <!-- Articles screens -->
    <string name="articles_title">Articles</string>
    <string name="articles_empty">No articles available yet.</string>
    <string name="articles_back_content_description">Back</string>
    <string name="articles_not_found">Article not found.</string>
    <string name="articles_detail_title_fallback">Article</string>
    <string name="articles_error">Couldn\'t load the articles.</string>
    <string name="articles_retry">Retry</string>

    <!-- Tasks list screen -->
    <string name="tasks_title">Tasks</string>
    <string name="tasks_empty">You have no tasks yet. Tap + to add one.</string>
    <string name="tasks_add_content_description">Add task</string>
    <string name="tasks_back_content_description">Back</string>
    <string name="tasks_delete_content_description">Delete task</string>
    <string name="tasks_start_content_description">Start countdown</string>
    <string name="tasks_pause_content_description">Pause countdown</string>
    <string name="tasks_time_up">Time\'s up</string>
    <string name="tasks_duration_label">Duration: %1$s</string>
    <!-- Duration pieces, assembled from locale-formatted numbers (%1$s/%2$s) so translators
         control the unit abbreviations and word order instead of the code concatenating them. -->
    <string name="tasks_duration_hours_minutes">%1$sh %2$smin</string>
    <string name="tasks_duration_hours">%1$sh</string>
    <string name="tasks_duration_minutes">%1$smin</string>
    <string name="tasks_deadline_label">Deadline: %1$s</string>
    <string name="tasks_delete_confirm_title">Delete task</string>
    <string name="tasks_delete_confirm_message">Delete “%1$s”?</string>
    <string name="tasks_delete_confirm_button">Delete</string>
    <string name="tasks_delete_cancel_button">Cancel</string>

    <!-- Task create/edit screen -->
    <string name="task_edit_title_create">New task</string>
    <string name="task_edit_title_edit">Edit task</string>
    <string name="task_edit_title_label">Title</string>
    <string name="task_edit_duration_label">Estimated duration (minutes)</string>
    <string name="task_edit_deadline_label">Deadline</string>
    <!-- Feature 14: native date/time picker for the deadline field. -->
    <string name="task_edit_deadline_pick_content_description">Pick deadline date and time</string>
    <string name="task_edit_deadline_clear_content_description">Clear deadline</string>
    <string name="task_edit_date_confirm">OK</string>
    <string name="task_edit_date_dismiss">Cancel</string>
    <string name="task_edit_save_button">Save</string>
    <string name="task_edit_delete_button">Delete task</string>
    <string name="tasks_error_blank_title">The title can\'t be empty.</string>
    <string name="tasks_error_invalid_duration">The duration must be a number of minutes greater than 0.</string>
    <string name="tasks_error_invalid_deadline_format">The deadline must use the format dd/MM/yyyy HH:mm.</string>
    <string name="tasks_error_missing_duration_or_deadline">Enter an estimated duration or a deadline.</string>

    <!-- Pending tasks home-screen widget -->
    <string name="widget_pending_tasks_title">Pending tasks</string>
    <string name="widget_pending_tasks_empty">You have no pending tasks.</string>
    <string name="widget_pending_tasks_description">Shows your pending tasks and the time left on each.</string>

    <!-- Lock-screen notification (feature 06) -->
    <string name="notification_channel_name">Pending tasks</string>
    <string name="notification_channel_description">Ongoing notification with your pending tasks and their remaining time.</string>
    <string name="notification_title">Pending tasks</string>
    <!-- Collapsed line: most urgent task title + its remaining time, e.g. "Call the doctor · 12:30". -->
    <string name="notification_content_text_format">%1$s · %2$s</string>
    <!-- One expanded InboxStyle row: task title + remaining time. -->
    <string name="notification_row_format">%1$s · %2$s</string>
    <!-- Redacted public (lock-screen) summary: count + most urgent remaining time, no titles. -->
    <plurals name="notification_public_summary">
        <item quantity="one">%1$d pending task · next in %2$s</item>
        <item quantity="other">%1$d pending tasks · next in %2$s</item>
    </plurals>

    <!-- Task reminders (feature 09): the alerting channel, separate from tasks_pending above. -->
    <string name="reminder_channel_name">Task reminders</string>
    <string name="reminder_channel_description">A one-off alert before a task is due.</string>
    <!-- Reminder notification body: minutes remaining (plural) + formatted deadline instant, e.g.
         "Due in 10 minutes · 12/24/2026 8:30 PM". %1$d is the minute count, %2$s the deadline. -->
    <plurals name="reminder_notification_body">
        <item quantity="one">Due in %1$d minute · %2$s</item>
        <item quantity="other">Due in %1$d minutes · %2$s</item>
    </plurals>

    <!-- Auth screens (feature 11): shared field labels -->
    <string name="auth_email_label">Email</string>
    <string name="auth_password_label">Password</string>
    <string name="auth_error_email_taken">That email is already registered.</string>
    <string name="auth_error_invalid_credentials">Wrong email or password.</string>
    <string name="auth_error_validation">Check your details: the email must be valid and the password at least 8 characters.</string>
    <string name="auth_error_network">No connection. Please try again.</string>
    <string name="auth_error_unknown">Something went wrong. Please try again.</string>

    <!-- Login screen -->
    <string name="login_title">Log in</string>
    <string name="login_button">Log in</string>
    <string name="login_register_prompt">Don\'t have an account? Register</string>
    <!-- Feature 13 (guest mode): only shown when this screen is opened from Settings (a guest
         choosing to sign in), never on the mandatory auth gate. -->
    <string name="login_back_content_description">Back</string>

    <!-- Register screen -->
    <string name="register_title">Create account</string>
    <string name="register_button">Register</string>
    <string name="register_back_content_description">Back</string>

    <!-- Settings screen: account (feature 11) -->
    <string name="settings_account_section">Account</string>
    <string name="settings_logout_button">Log out</string>
    <!-- Feature 13 (guest mode): shown instead of "Log out" while the user is a guest (no account). -->
    <string name="settings_sign_in_button">Sign in / Create account</string>

    <!-- Tasks list screen: minimal sync status hint (feature 11, OQ-1) -->
    <string name="tasks_sync_offline">Offline. Changes will sync later.</string>
    <string name="tasks_sync_error">Couldn\'t sync. Will retry automatically.</string>
</resources>
