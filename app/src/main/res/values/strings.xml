    <!-- Pending tasks home-screen widget -->
    <string name="widget_pending_tasks_title">Tareas pendientes</string>
    <string name="widget_pending_tasks_empty">No tienes tareas pendientes.</string>
    <string name="widget_pending_tasks_description">Muestra tus tareas pendientes y el tiempo restante de cada una.</string>

    <!-- Lock-screen notification (feature 06) -->
    <string name="notification_channel_name">Tareas pendientes</string>
    <string name="notification_channel_description">Notificación continua con tus tareas pendientes y su tiempo restante.</string>
    <string name="notification_title">Tareas pendientes</string>
    <!-- Collapsed line: most urgent task title + its remaining time, e.g. "Llamar al médico · 12:30". -->
    <string name="notification_content_text_format">%1$s · %2$s</string>
    <!-- One expanded InboxStyle row: task title + remaining time. -->
    <string name="notification_row_format">%1$s · %2$s</string>
    <!-- Redacted public (lock-screen) summary: count + most urgent remaining time, no titles.
         A <plurals> resource so the count agrees grammatically ("1 tarea" vs "3 tareas"); %1$d is
         the count (locale-formatted by the resource system) and %2$s the most urgent remaining
         time. -->
    <plurals name="notification_public_summary">
        <item quantity="one">%1$d tarea pendiente · próxima en %2$s</item>
        <item quantity="other">%1$d tareas pendientes · próxima en %2$s</item>
    </plurals>

    <!-- Task reminders (feature 09): the alerting channel, separate from tasks_pending above. -->
    <string name="reminder_channel_name">Recordatorios de tareas</string>
    <string name="reminder_channel_description">Aviso puntual antes de que venza una tarea.</string>
    <!-- Reminder notification body: minutes remaining (plural) + formatted deadline instant, e.g.
         "Vence en 10 minutos · 24/12/2026 20:30". %1$d is the minute count, %2$s the deadline. -->
    <plurals name="reminder_notification_body">
        <item quantity="one">Vence en %1$d minuto · %2$s</item>
        <item quantity="other">Vence en %1$d minutos · %2$s</item>
    </plurals>

