    <!-- Tasks list screen -->
    <string name="tasks_title">Tareas</string>
    <!-- The action button on the empty state already invites the user to add a task (feature 17),
         so this message stays purely informational rather than repeating "Pulsa +". -->
    <string name="tasks_empty">No tienes tareas todavía.</string>
    <string name="tasks_empty_action">Añadir tarea</string>
    <string name="tasks_add_content_description">Añadir tarea</string>
    <!-- One-shot snackbar (feature 17), shown once after creating a task — see AppNavHost's
         create-only Task Edit wiring and TasksRoute's SavedStateHandle collection. -->
    <string name="tasks_task_created_snackbar">Tarea creada.</string>
    <string name="tasks_back_content_description">Volver</string>
    <string name="tasks_delete_content_description">Borrar tarea</string>
    <string name="tasks_start_content_description">Iniciar cuenta atrás</string>
    <string name="tasks_pause_content_description">Pausar cuenta atrás</string>
    <string name="tasks_time_up">Tiempo agotado</string>
    <!-- Feature 19: accessibility state description for the determinate progress bar, announced by
         screen readers alongside the bar's own built-in progress semantics. %1$s is a locale-formatted
         percentage (e.g. "45%"), not concatenated in code. -->
    <string name="tasks_progress_state_description">%1$s transcurrido</string>
    <string name="tasks_duration_label">Duración: %1$s</string>
    <!-- Duration pieces, assembled from locale-formatted numbers (%1$s/%2$s) so translators
         control the unit abbreviations and word order instead of the code concatenating them. -->
    <string name="tasks_duration_hours_minutes">%1$s h %2$s min</string>
    <string name="tasks_duration_hours">%1$s h</string>
    <string name="tasks_duration_minutes">%1$s min</string>
    <string name="tasks_deadline_label">Fecha límite: %1$s</string>
    <string name="tasks_delete_confirm_title">Borrar tarea</string>
    <string name="tasks_delete_confirm_message">¿Seguro que quieres borrar «%1$s»?</string>
    <string name="tasks_delete_confirm_button">Borrar</string>
    <string name="tasks_delete_cancel_button">Cancelar</string>

    <!-- Feature 03b: in-memory filter/sort/group controls, above the list. -->
    <string name="tasks_filter_label">Buscar por título</string>
    <string name="tasks_sort_deadline">Plazo</string>
    <string name="tasks_sort_title">Título</string>
