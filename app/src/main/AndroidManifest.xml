<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Lock-screen notification (feature 06). POST_NOTIFICATIONS is a runtime permission on
         Android 13+ (API 33): the app must request it (see RequestNotificationPermissionEffect);
         declaring it here is harmless on API 24-32, where it is granted implicitly.
         FOREGROUND_SERVICE + FOREGROUND_SERVICE_SPECIAL_USE let TasksNotificationService run as a
         foreground service; SPECIAL_USE is the honest type for an ongoing task summary that fits
         none of the concrete categories (location, media, etc.). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Task reminders (feature 09). SCHEDULE_EXACT_ALARM (API 31+) lets the app ask AlarmManager
         for exact, Doze-aware alarms via setExactAndAllowWhileIdle; canScheduleExactAlarms() is
         still checked at runtime (see AlarmManagerReminderScheduler) because this permission can
         be revoked, and the app gracefully falls back to an inexact alarm when it is not granted.
         Declaring it is a no-op on API < 31, where exact alarms need no special permission at all;
         OQ-1 deliberately does NOT declare USE_EXACT_ALARM (API 33+), which Google Play restricts
         to alarm/clock/calendar apps.
         RECEIVE_BOOT_COMPLETED (a normal permission, granted at install time) lets BootReceiver
         hear BOOT_COMPLETED and reprogram every future reminder that the reboot just wiped. -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Articles from a remote API (feature 10). INTERNET is a *normal* permission: it is granted
         automatically at install time and needs no runtime request (unlike POST_NOTIFICATIONS
         above). Required by ArticlesApi/ArticlesNetwork (Retrofit + OkHttp) to reach the remote
         JSON endpoint over HTTPS. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.NeverLate">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.NeverLate">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Pending-tasks home-screen widget (feature 05). AppWidgetManager delivers
             APPWIDGET_UPDATE broadcasts here; GlanceAppWidgetReceiver forwards them to
             PendingTasksWidget. android:exported="true" is required for widget receivers so the
             launcher (a different app/process) can deliver those broadcasts. -->
        <receiver
            android:name=".ui.widget.PendingTasksWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_pending_tasks_title">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/pending_tasks_widget_info" />
        </receiver>

        <!-- Foreground service hosting the ongoing lock-screen notification (feature 06).
             android:exported="false": nothing outside the app ever starts it — only the app's own
             decorator/worker/Activity do, via TasksNotificationService.refresh().
             android:foregroundServiceType="specialUse" is required from API 34+ (targetSdk 36); the
             matching FOREGROUND_SERVICE_SPECIAL_USE permission is declared above. -->
        <service
            android:name=".ui.notification.TasksNotificationService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Ongoing summary of the user's pending tasks and their remaining time on the lock screen." />
        </service>

        <!-- Fires one task's reminder at the exact instant AlarmManagerReminderScheduler
             scheduled it (feature 09). exported="false": only this app's own alarm PendingIntent
             can deliver this broadcast, never another app. -->
        <receiver
            android:name=".ui.notification.ReminderReceiver"
            android:exported="false" />

        <!-- Reprograms every future reminder after a device restart (US-2), which wipes all
             AlarmManager alarms. exported="true" is required for the system to deliver
             BOOT_COMPLETED here; the receiver itself does no sensitive work, it only enqueues
             BootRescheduleWorker. -->
        <receiver
            android:name=".ui.notification.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
    </application>

</manifest>
