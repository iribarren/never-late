<?xml version="1.0" encoding="utf-8"?>
<!--
    Debug-variant manifest fragment (feature 11): merged ONLY into debug builds, on top of
    app/src/main/AndroidManifest.xml. Adds the debug-only network security config that permits
    cleartext HTTP to the local dev backend (see res/xml/network_security_config.xml for why).
    Release builds never see this attribute, so they keep the secure platform default (no
    cleartext at all).
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application android:networkSecurityConfig="@xml/network_security_config" />
</manifest>
